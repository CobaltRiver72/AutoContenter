# ─────────────────────────────────────────────────────────────────────────────
# HDF News AutoPub — Environment Configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
# Port for the Express dashboard / API server
PORT=3000

# Password for the web dashboard login
DASHBOARD_PASSWORD=

# ─── Ahrefs Firehose ────────────────────────────────────────────────────────
# SSE token for the Ahrefs Firehose API
# If not set, the firehose listener will not start (app still runs)
FIREHOSE_TOKEN=

# Language filter — comma-separated ISO codes the firehose will accept.
# Articles in any other language are dropped at intake. Default: en,hi.
# ALLOWED_LANGUAGES=en,hi

# ─── AI Rewriting ───────────────────────────────────────────────────────────
# Primary model: Anthropic Claude (used first)
ANTHROPIC_API_KEY=
# AI_PRIMARY_MODEL=claude-sonnet-4-20250514

# Fallback model: OpenAI GPT (used if Claude fails)
OPENAI_API_KEY=
# AI_FALLBACK_MODEL=gpt-4o-mini

# ─── WordPress Publishing ───────────────────────────────────────────────────
# Full URL of the WordPress site (e.g., https://example.com)
WP_URL=

# WordPress username with publish permissions
WP_USERNAME=

# WordPress Application Password (generate in WP Admin → Users → App Passwords)
WP_APP_PASSWORD=

# Default author ID for published posts
# WP_AUTHOR_ID=1

# Default category ID for published posts
# WP_DEFAULT_CATEGORY=1

# Post status on publish: 'publish' or 'draft'
# WP_POST_STATUS=publish

# ─── Google Trends ──────────────────────────────────────────────────────────
# Enable/disable Google Trends polling (may not work on server IPs)
TRENDS_ENABLED=false

# Geographic region for trends (ISO 3166-1 alpha-2)
# TRENDS_GEO=IN

# How often to poll Google Trends (minutes)
# TRENDS_POLL_MINUTES=15

# ─── Article Clustering ─────────────────────────────────────────────────────
# Minimum number of sources required before publishing a cluster
# MIN_SOURCES_THRESHOLD=2

# TF-IDF cosine similarity threshold for matching articles (0.0 - 1.0)
# SIMILARITY_THRESHOLD=0.20

# Hours to keep articles in the rolling buffer
# BUFFER_HOURS=6

# Allow articles from the same domain to cluster (uses stricter threshold)
# ALLOW_SAME_DOMAIN_CLUSTERS=false

# ─── Publish Rate Limits ────────────────────────────────────────────────────
# Maximum articles to publish per hour
# MAX_PUBLISH_PER_HOUR=4

# Minimum minutes between consecutive publishes
# PUBLISH_COOLDOWN_MINUTES=10

# ─── Source Authority Tiers ──────────────────────────────────────────────────
# Comma-separated domains for each tier (higher tier = more authoritative)
# TIER1_SOURCES=ndtv.com,hindustantimes.com,timesofindia.indiatimes.com,thehindu.com,indianexpress.com
# TIER2_SOURCES=livemint.com,business-standard.com,deccanherald.com,firstpost.com,news18.com
# TIER3_SOURCES=zeenews.india.com,republicworld.com,wionews.com,aninews.in

# ─── InfraNodus (optional semantic analysis) ───────────────────────────────
# API key from infranodus.com account settings
INFRANODUS_API_KEY=
INFRANODUS_ENABLED=false

# ─── Jina AI Reader (extraction fallback) ──────────────────────────────────
# Third-tier extraction layer used when direct fetch + Google Cache both fail.
# Calls https://r.jina.ai/{url} which returns clean markdown for any URL.
# Optional API key from jina.ai (works without one at low rate limits).
JINA_API_KEY=
JINA_ENABLED=true

# ─── Logging ────────────────────────────────────────────────────────────────
# Log level: error, warn, info, debug
# LOG_LEVEL=info
