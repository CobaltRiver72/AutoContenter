{
  "name": "hdf-news-autopub",
  "version": "1.0.0",
  "description": "Ahrefs Firehose + Google Trends → AI Rewrite → WordPress Auto-Publisher",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "prod": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop hdf-autopub",
    "restart": "pm2 restart hdf-autopub",
    "logs": "pm2 logs hdf-autopub --lines 100"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@mozilla/readability": "^0.5.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "eventsource": "^2.0.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "google-trends-api": "^4.9.2",
    "helmet": "^7.1.0",
    "jsdom": "^24.0.0",
    "natural": "^8.0.1",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "uuid": "^13.0.0",
    "winston": "^3.14.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
